<!DOCTYPE html>
<html lang="<%= model.t.htmlLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex">
    <title><%= model.pageTitle %></title>
    <link rel="preconnect" href="https://cdn.jsdelivr.net">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <style>
        body { background: #f5f7fb; }
        .audit-shell { max-width: 1120px; }
        .audit-card { border-radius: 1.25rem; }
        .audit-kpi { min-height: 100%; }
        .audit-dl dt { font-weight: 600; }
        .audit-dl dd { margin-bottom: 0.75rem; }
        .table td, .table th { vertical-align: top; }
        @media print {
            body { background: #fff; }
            .no-print { display: none !important; }
            .audit-card { box-shadow: none !important; border: 0 !important; }
        }
    </style>
</head>
<body>
    <div class="container-fluid py-4 py-lg-5 audit-shell">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4 no-print">
            <div>
                <h1 class="h2 mb-1"><%= model.t.pageTitle %></h1>
                <p class="text-secondary mb-0"><%= model.t.lead %></p>
            </div>
            <div class="d-flex align-items-center gap-2">
                <button id="copy-html-button" type="button" class="btn btn-primary" data-copy-target="cms-copy-root">
                    <%= model.t.copyButton %>
                </button>
            </div>
        </div>

        <div id="copy-feedback" class="alert d-none no-print" role="status" aria-live="polite"></div>

        <div id="cms-copy-root" class="bg-white border shadow-sm p-4 p-lg-5 audit-card">
            <header class="mb-4 pb-3 border-bottom">
                <div class="d-flex flex-column flex-xl-row justify-content-between gap-3">
                    <div>
                        <p class="text-uppercase small text-secondary mb-2"><%= model.t.generatedNotice %></p>
                        <h1 class="display-6 mb-2"><%= model.pageTitle %></h1>
                        <p class="lead mb-0"><%= model.t.lead %></p>
                    </div>
                    <div class="text-secondary small">
                        <div><strong><%= model.t.auditDate %>:</strong> <%= model.generatedAtDisplay %></div>
                        <div><strong><%= model.t.siteUrl %>:</strong> <a href="<%= model.origin %>"><%= model.origin %></a></div>
                    </div>
                </div>
            </header>

            <section class="mb-5">
                <h2 class="h4 mb-3"><%= model.t.sectionWhy %></h2>
                <% for (const paragraph of model.t.whyParagraphs) { %>
                    <p><%= paragraph %></p>
                <% } %>
            </section>

            <section class="mb-5">
                <h2 class="h4 mb-3"><%= model.t.sectionHow %></h2>
                <% for (const paragraph of model.t.howParagraphs) { %>
                    <p><%= paragraph %></p>
                <% } %>
                <ul class="mb-0">
                    <% for (const bullet of model.t.howBullets) { %>
                        <li><%= bullet %></li>
                    <% } %>
                </ul>
            </section>

            <section class="mb-5">
                <h2 class="h4 mb-3"><%= model.t.sectionResults %></h2>
                <div class="row g-4 mb-4">
                    <div class="col-12 col-lg-5">
                        <div class="border rounded-4 p-4 h-100 audit-kpi bg-light-subtle">
                            <h3 class="h5 mb-3"><%= model.t.generalInfo %></h3>
                            <dl class="row audit-dl mb-0">
                                <dt class="col-sm-5"><%= model.t.siteName %></dt>
                                <dd class="col-sm-7"><%= model.siteName %></dd>
                                <dt class="col-sm-5"><%= model.t.siteUrl %></dt>
                                <dd class="col-sm-7"><a href="<%= model.origin %>"><%= model.origin %></a></dd>
                                <dt class="col-sm-5"><%= model.t.auditStartedAt %></dt>
                                <dd class="col-sm-7"><%= model.startedAtDisplay %></dd>
                                <dt class="col-sm-5"><%= model.t.auditEndedAt %></dt>
                                <dd class="col-sm-7"><%= model.endedAtDisplay %></dd>
                                <dt class="col-sm-5"><%= model.t.auditType %></dt>
                                <dd class="col-sm-7"><%= model.t.auditTypeValue %></dd>
                                <dt class="col-sm-5"><%= model.t.standard %></dt>
                                <dd class="col-sm-7"><%= model.t.standardValue %></dd>
                                <dt class="col-sm-5"><%= model.t.auditTool %></dt>
                                <dd class="col-sm-7"><%= model.t.auditToolValue %></dd>
                                <dt class="col-sm-5"><%= model.t.pagesChecked %></dt>
                                <dd class="col-sm-7"><%= model.pagesChecked %></dd>
                            </dl>
                        </div>
                    </div>
                    <div class="col-12 col-lg-7">
                        <div class="border rounded-4 p-4 h-100 audit-kpi">
                            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-3">
                                <div>
                                    <h3 class="h5 mb-1"><%= model.t.complianceStatusLabel %></h3>
                                    <p class="text-secondary mb-0"><%= model.t.summaryLead %></p>
                                </div>
                                <span class="badge fs-6 <%= model.statusBadgeClass %>"><%= model.statusLabel %></span>
                            </div>
                            <p class="mb-4"><%= model.statusDescription %></p>
                            <div class="row g-3">
                                <div class="col-6 col-xl-3">
                                    <div class="border rounded-3 p-3 bg-light h-100">
                                        <div class="small text-secondary"><%= model.t.summaryCards.findings %></div>
                                        <div class="fs-3 fw-semibold"><%= model.findingCount %></div>
                                    </div>
                                </div>
                                <div class="col-6 col-xl-3">
                                    <div class="border rounded-3 p-3 bg-light h-100">
                                        <div class="small text-secondary"><%= model.t.summaryCards.ruleGroups %></div>
                                        <div class="fs-3 fw-semibold"><%= model.groupedFindingCount %></div>
                                    </div>
                                </div>
                                <div class="col-6 col-xl-3">
                                    <div class="border rounded-3 p-3 bg-light h-100">
                                        <div class="small text-secondary"><%= model.t.summaryCards.affectedPages %></div>
                                        <div class="fs-3 fw-semibold"><%= model.affectedPageCount %></div>
                                    </div>
                                </div>
                                <div class="col-6 col-xl-3">
                                    <div class="border rounded-3 p-3 bg-light h-100">
                                        <div class="small text-secondary"><%= model.t.summaryCards.plugins %></div>
                                        <div class="fs-3 fw-semibold"><%= model.pluginCount %></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-12 col-xl-4">
                        <div class="border rounded-4 p-4 h-100">
                            <h3 class="h5 mb-3"><%= model.t.pluginBreakdownTitle %></h3>
                            <% if (model.pluginBreakdown.length === 0) { %>
                                <p class="mb-0 text-secondary"><%= model.t.noFindings %></p>
                            <% } else { %>
                                <div class="list-group list-group-flush">
                                    <% for (const plugin of model.pluginBreakdown) { %>
                                        <div class="list-group-item px-0 py-3">
                                            <div class="d-flex justify-content-between align-items-start gap-3">
                                                <div>
                                                    <div class="fw-semibold"><%= plugin.name %></div>
                                                    <div class="small text-secondary"><%= model.t.breakdownErrors %>: <%= plugin.errors %> | <%= model.t.breakdownWarnings %>: <%= plugin.warnings %> | <%= model.t.breakdownInfos %>: <%= plugin.infos %></div>
                                                </div>
                                                <span class="badge text-bg-secondary"><%= plugin.total %></span>
                                            </div>
                                        </div>
                                    <% } %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                    <div class="col-12 col-xl-8">
                        <div class="border rounded-4 p-4 h-100">
                            <h3 class="h5 mb-2"><%= model.t.findingsTitle %></h3>
                            <p class="text-secondary"><%= model.t.findingsLead %></p>
                            <% if (model.findings.length === 0) { %>
                                <div class="alert alert-success mb-0"><%= model.t.noFindings %></div>
                            <% } else { %>
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle mb-0">
                                        <thead>
                                            <tr>
                                                <th scope="col"><%= model.t.columns.severity %></th>
                                                <th scope="col"><%= model.t.columns.plugin %></th>
                                                <th scope="col"><%= model.t.columns.code %></th>
                                                <th scope="col"><%= model.t.columns.message %></th>
                                                <th scope="col" class="text-end"><%= model.t.columns.pages %></th>
                                                <th scope="col"><%= model.t.columns.example %></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% for (const finding of model.findings) { %>
                                                <tr>
                                                    <td><span class="badge <%= finding.severity === 'error' ? 'text-bg-danger' : finding.severity === 'warning' ? 'text-bg-warning' : 'text-bg-secondary' %>"><%= finding.severityLabel %></span></td>
                                                    <td><%= finding.pluginLabel %></td>
                                                    <td><code><%= finding.code %></code></td>
                                                    <td>
                                                        <div><%= finding.message %></div>
                                                        <div class="small text-secondary"><%= model.t.occurrences %>: <%= finding.occurrences %></div>
                                                    </td>
                                                    <td class="text-end"><%= finding.pages %></td>
                                                    <td>
                                                        <% if (finding.exampleUrl) { %>
                                                            <a href="<%= finding.exampleUrl %>"><%= finding.exampleUrl %></a>
                                                        <% } else { %>
                                                            <span class="text-secondary">-</span>
                                                        <% } %>
                                                    </td>
                                                </tr>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </section>

            <section>
                <h2 class="h4 mb-3"><%= model.t.appendixTitle %></h2>
                <p><%= model.t.appendixParagraph %></p>
                <p class="text-secondary small mb-0"><%= model.t.rawMessagesNotice %></p>
            </section>
        </div>
    </div>

    <script>
        (() => {
            const button = document.getElementById("copy-html-button");
            const feedback = document.getElementById("copy-feedback");
            const successMessage = <%- JSON.stringify(model.t.copySuccess) %>;
            const errorMessage = <%- JSON.stringify(model.t.copyError) %>;

            if (!button) {
                return;
            }

            async function writeClipboard(html, text) {
                if (navigator.clipboard && window.ClipboardItem) {
                    const item = new ClipboardItem({
                        "text/html": new Blob([html], { type: "text/html" }),
                        "text/plain": new Blob([text], { type: "text/plain" }),
                    });
                    await navigator.clipboard.write([item]);
                    return;
                }

                if (navigator.clipboard && navigator.clipboard.writeText) {
                    await navigator.clipboard.writeText(text);
                    return;
                }

                throw new Error("clipboard_unavailable");
            }

            function showFeedback(message, type) {
                if (!feedback) {
                    return;
                }
                feedback.className = `alert alert-${type} no-print`;
                feedback.textContent = message;
                feedback.classList.remove("d-none");
            }

            button.addEventListener("click", async () => {
                const targetId = button.getAttribute("data-copy-target");
                const target = targetId ? document.getElementById(targetId) : null;
                if (!target) {
                    showFeedback(errorMessage, "danger");
                    return;
                }

                const html = target.innerHTML.trim();
                const text = target.innerText.trim();

                try {
                    await writeClipboard(html, text);
                    showFeedback(successMessage, "success");
                } catch (error) {
                    console.error(error);
                    showFeedback(errorMessage, "danger");
                }
            });
        })();
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
