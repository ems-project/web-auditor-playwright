<!DOCTYPE html>
<html lang="<%= model.t.htmlLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex">
    <title><%= model.t.pageTitle %></title>
    <link rel="preconnect" href="https://cdn.jsdelivr.net">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <style>
        body {
            background: #f5f6f8;
            color: #1f2937;
        }
        .page-shell {
            max-width: 1200px;
        }
        .page-card {
            background: #fff;
            border-radius: 1.25rem;
            box-shadow: 0 1rem 3rem rgba(15, 23, 42, 0.08);
        }
        .copy-surface h2,
        .copy-surface h3,
        .copy-surface h4,
        .copy-surface h5 {
            color: #074374;
        }
        .copy-surface h2 {
            margin-bottom: 1rem;
        }
        .copy-surface h3 {
            margin-top: 2rem;
            margin-bottom: 0.75rem;
        }
        .copy-surface h4 {
            margin-top: 1.5rem;
            margin-bottom: 0.5rem;
        }
        .copy-surface h5 {
            margin-top: 1.25rem;
            margin-bottom: 0.5rem;
        }
        .copy-surface .table th {
            background: #f8fafc;
        }
        .copy-surface .table td,
        .copy-surface .table th {
            vertical-align: top;
        }
        .copy-surface .lead {
            color: #475569;
        }
        .section-block + .section-block {
            margin-top: 2.5rem;
        }
        .back-link {
            font-size: 0.95rem;
            text-decoration: none;
        }
        .criterion-list {
            margin: 0;
            padding-left: 1.1rem;
        }
        .criterion-list li + li {
            margin-top: 0.35rem;
        }
        @media print {
            body {
                background: #fff;
            }
            .no-print {
                display: none !important;
            }
            .page-card {
                box-shadow: none;
                border: none;
            }
        }
    </style>
</head>
<body>
    <div class="container py-4 py-lg-5 page-shell">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4 no-print">
            <div>
                <p class="text-secondary mb-0"><%= model.t.lead %></p>
            </div>
            <button id="copy-html-button" type="button" class="btn btn-primary" data-copy-target="cms-copy-root">
                <%= model.t.copyButton %>
            </button>
        </div>

        <div id="copy-feedback" class="alert d-none no-print" role="status" aria-live="polite"></div>

        <div class="page-card p-4 p-lg-5 copy-surface" id="cms-copy-root">
            <div class="row">
                <div class="col-12 offset-lg-1 col-lg-10">
                    <header class="mb-4">
                        <h1 class="mt-3"><%= model.t.pageTitle %></h1>
                    </header>

                    <article>
                        <section id="general-info" class="section-block">
                            <h2><%= model.t.generalInfo %></h2>
                            <dl class="row mb-0">
                                <dt class="col-sm-4"><%= model.t.siteUrl %></dt>
                                <dd class="col-sm-8"><%= model.origin %></dd>
                                <dt class="col-sm-4"><%= model.t.auditDate %></dt>
                                <dd class="col-sm-8"><%= model.generatedAtDisplay %></dd>
                                <dt class="col-sm-4"><%= model.t.auditType %></dt>
                                <dd class="col-sm-8"><%= model.t.auditTypeValue %></dd>
                                <dt class="col-sm-4"><%= model.t.standard %></dt>
                                <dd class="col-sm-8"><%= model.t.standardValue %></dd>
                                <dt class="col-sm-4"><%= model.t.pagesChecked %></dt>
                                <dd class="col-sm-8"><%= model.pagesChecked %></dd>
                                <dt class="col-sm-4"><%= model.t.complianceStatusLabel %></dt>
                                <dd class="col-sm-8"><strong><%= model.statusLabel %></strong>.<br><span class="text-secondary"><%= model.statusDescription %></span></dd>
                            </dl>
                        </section>

                        <section class="section-block">
                            <h2><%= model.t.sectionWhy %></h2>
                            <% for (const paragraph of model.t.whyParagraphs) { %>
                                <p><%= paragraph %></p>
                            <% } %>
                        </section>

                        <section class="section-block">
                            <h2><%= model.t.sectionHow %></h2>
                            <% for (const paragraph of model.t.howParagraphs) { %>
                                <p><%= paragraph %></p>
                            <% } %>
                            <ul>
                                <% for (const bullet of model.t.howBullets) { %>
                                    <li><%= bullet %></li>
                                <% } %>
                            </ul>
                        </section>

                        <section id="audit" class="section-block">
                            <h2><%= model.t.sectionResults %></h2>
                            <p><%= model.t.criteriaLead %></p>
                            <% for (const principle of model.axePrinciples) { %>
                                <section class="mt-4">
                                    <h3><%= principle.code %>. <%= principle.title %></h3>
                                    <% if (principle.description) { %>
                                        <p class="text-secondary"><%= principle.description %></p>
                                    <% } %>
                                    <% for (const guideline of principle.guidelines) { %>
                                        <section class="mt-4">
                                            <h4><%= guideline.code %> <%= guideline.title %></h4>
                                            <% if (guideline.description) { %>
                                                <p class="text-secondary"><%= guideline.description %></p>
                                            <% } %>
                                            <div class="table-responsive">
                                                <table class="table table-bordered align-middle">
                                                    <thead>
                                                        <tr>
                                                            <th scope="col"><%= model.t.columns.criterion %></th>
                                                            <th scope="col"><%= model.t.columns.status %></th>
                                                            <th scope="col" style="width: 42%"><%= model.t.columns.description %></th>
                                                            <th scope="col"><%= model.t.columns.pages %></th>
                                                            <th scope="col"><%= model.t.occurrences %></th>
                                                            <th scope="col"><%= model.t.columns.references %></th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <% for (const criterion of guideline.criteria) { %>
                                                            <tr>
                                                                <td>
                                                                    <strong><%= criterion.criterion %></strong><br>
                                                                    <span><%= criterion.criterionTitle %></span>
                                                                </td>
                                                                <td><span class="badge <%= criterion.statusBadgeClass %>"><%= criterion.statusLabel %></span></td>
                                                                <td>
                                                                    <div class="small text-secondary mb-2"><%= model.t.columns.checks %></div>
                                                                    <ul class="criterion-list mb-0">
                                                                        <% for (const check of criterion.checks) { %>
                                                                            <li><%= check %></li>
                                                                        <% } %>
                                                                    </ul>
                                                                    <% if (criterion.findingMessages.length > 0) { %>
                                                                        <div class="small text-secondary mt-3 mb-2"><%= model.t.detectedFindingsLabel %></div>
                                                                        <ul class="criterion-list mb-0">
                                                                            <% for (const finding of criterion.findingMessages) { %>
                                                                                <li><%= finding %></li>
                                                                            <% } %>
                                                                        </ul>
                                                                    <% } %>
                                                                </td>
                                                                <td><%= criterion.pages %></td>
                                                                <td><%= criterion.occurrences %></td>
                                                                <td>
                                                                    <% if (criterion.references.length > 0) { %>
                                                                        <ul class="criterion-list mb-0">
                                                                            <% for (const ref of criterion.references) { %>
                                                                                <li><a href="<%= ref.url %>"><%= ref.label %></a></li>
                                                                            <% } %>
                                                                        </ul>
                                                                    <% } %>
                                                                </td>
                                                            </tr>
                                                        <% } %>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </section>
                                    <% } %>
                                </section>
                            <% } %>
                        </section>

                        <section class="section-block">
                            <h2><%= model.t.appendixTitle %></h2>
                            <p><%= model.t.appendixParagraph %></p>
                            <p class="text-secondary"><%= model.t.rawMessagesNotice %></p>
                        </section>
                    </article>
                </div>
            </div>
        </div>
    </div>

    <script>
        (() => {
            const button = document.getElementById("copy-html-button");
            const feedback = document.getElementById("copy-feedback");
            const successMessage = <%- JSON.stringify(model.t.copySuccess) %>;
            const errorMessage = <%- JSON.stringify(model.t.copyError) %>;

            if (!button) {
                return;
            }

            async function writeClipboard(html, text) {
                if (navigator.clipboard && window.ClipboardItem) {
                    const item = new ClipboardItem({
                        "text/html": new Blob([html], { type: "text/html" }),
                        "text/plain": new Blob([text], { type: "text/plain" }),
                    });
                    await navigator.clipboard.write([item]);
                    return;
                }

                if (navigator.clipboard && navigator.clipboard.writeText) {
                    await navigator.clipboard.writeText(text);
                    return;
                }

                throw new Error("clipboard_unavailable");
            }

            function showFeedback(message, type) {
                if (!feedback) {
                    return;
                }
                feedback.className = `alert alert-${type} no-print`;
                feedback.textContent = message;
                feedback.classList.remove("d-none");
            }

            button.addEventListener("click", async () => {
                const targetId = button.getAttribute("data-copy-target");
                const target = targetId ? document.getElementById(targetId) : null;
                if (!target) {
                    showFeedback(errorMessage, "danger");
                    return;
                }

                const html = target.innerHTML.trim();
                const text = target.innerText.trim();

                try {
                    await writeClipboard(html, text);
                    showFeedback(successMessage, "success");
                } catch (error) {
                    console.error(error);
                    showFeedback(errorMessage, "danger");
                }
            });
        })();
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
